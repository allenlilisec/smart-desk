{
  "name": "smartdesk-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:mock": "E2E_MODE=mock playwright test",
    "e2e:debug": "playwright test --debug",
    "generate:types": "openapi-typescript openapi/gateway.yaml -o src/types/gateway.d.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.2.9",
    "openapi-typescript": "^7.13.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0",
    "@playwright/test": "^1.40.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "esbuild": "^0.25.0"
  }
}
