# SmartDesk Web 环境变量模板
# 复制此文件为 .env.local 以在本地开发

# ============================================
# 应用配置
# ============================================
NEXT_PUBLIC_APP_NAME=SmartDesk
NEXT_PUBLIC_APP_VERSION=0.1.0

# ============================================
# API 配置
# ============================================
# 后端 API 基础地址（开发环境）
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# 认证配置
# ============================================
# JWT 相关配置（如果需要）
# NEXT_PUBLIC_AUTH_TOKEN_KEY=smartdesk_token

# ============================================
# 其他配置
# ============================================
# 开发端口
PORT=3000

# Node 环境
NODE_ENV=development
