# E2E 测试环境配置
# 复制此文件为 .env.e2e 并填写实际值

# 运行模式: mock | real
E2E_MODE=mock

# 前端应用 baseURL
E2E_BASE_URL=http://localhost:3000

# Gateway API 地址（真实模式需要）
E2E_GATEWAY_URL=http://localhost:8080

# 测试账号配置
# 报单人账号
E2E_PORTAL_USER=zhangsan
E2E_PORTAL_PASSWORD=password123

# 坐席账号
E2E_AGENT_USER=lisi
E2E_AGENT_PASSWORD=password123

# 管理员账号
E2E_ADMIN_USER=admin
E2E_ADMIN_PASSWORD=password123

# CI 模式标记（GitHub Actions 自动设置）
CI=false
