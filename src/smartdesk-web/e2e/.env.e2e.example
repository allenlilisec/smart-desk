# E2E 测试环境变量配置

# ═══════════════════════════════════════════════════════════
# 运行模式配置
# ═══════════════════════════════════════════════════════════

# 运行模式: mock 或 real
# - mock: 使用 Playwright 拦截 API 请求，无需后端服务
# - real: 调用真实 Gateway 服务
E2E_MODE=mock

# ═══════════════════════════════════════════════════════════
# 基础 URL 配置
# ═══════════════════════════════════════════════════════════

# 测试站点基础 URL
# Mock 模式下: 本地开发服务器地址
# Real 模式下: Gateway 服务地址
E2E_BASE_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════
# 真实 Gateway 模式配置（仅在 E2E_MODE=real 时生效）
# ═══════════════════════════════════════════════════════════

# Gateway 服务地址
E2E_GATEWAY_URL=http://localhost:3001

# 测试账号配置（真实模式下使用）
E2E_TEST_USER_ZHANGSAN=zhangsan
E2E_TEST_PASS_ZHANGSAN=test123

E2E_TEST_USER_LISI=lisi
E2E_TEST_PASS_LISI=test123

E2E_TEST_USER_ADMIN=admin
E2E_TEST_PASS_ADMIN=admin123

# ═══════════════════════════════════════════════════════════
# 测试行为配置
# ═══════════════════════════════════════════════════════════

# 是否启用延迟模拟（模拟真实网络延迟）
E2E_ENABLE_DELAY=false
E2E_DEFAULT_DELAY=200

# 是否启用错误模拟（用于测试降级场景）
E2E_ERROR_RATE=0
