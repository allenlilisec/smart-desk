# smartdesk-core configuration (copy to .env / export in your shell).
CORE_ENV=dev
CORE_HTTP_ADDR=:8080
CORE_LOG_LEVEL=info
# Leave empty to run without a database (readiness reports DB disabled).
CORE_DATABASE_URL=postgres://smartdesk:smartdesk@localhost:5432/smartdesk?sslmode=disable
CORE_SHUTDOWN_TIMEOUT=15s
CORE_SERVICE_JWT_AUD=core
CORE_EVENT_BUS_URL=
