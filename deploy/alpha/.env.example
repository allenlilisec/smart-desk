# Alpha/Beta 隔离测试栈环境变量
# 复制为 .env 后按需修改：cp .env.example .env

# --- 对外端口（仅 gateway + web 映射宿主机）---
GATEWAY_PORT=8080
WEB_PORT=3001

# --- 浏览器访问 gateway API（须与 GATEWAY_PORT 一致）---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
CORS_ORIGINS=http://localhost:3001

# --- 镜像 tag（SUP-211 归档 / 武安镜像基线扫描）---
IMAGE_TAG=alpha-mvp

# --- gateway 认证（Alpha 使用本地种子用户；生产须改为 production）---
GATEWAY_NODE_ENV=development

JWT_SECRET=alpha-beta-smartdesk-jwt-secret-32b-min

# --- PostgreSQL ---
POSTGRES_USER=smartdesk
POSTGRES_PASSWORD=smartdesk
POSTGRES_DB=smartdesk_core

# --- MinIO（附件对象存储，内部网络）---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- 服务标识 ---
CORE_ORG_ID=default
DEFAULT_ORG_ID=default
